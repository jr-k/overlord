{
  "name": "overlord",
  "version": "0.1.5",
  "description": "Project multiplexer with Claude integration",
  "author": {
    "name": "Overlord",
    "email": "hello@poptocrack.com"
  },
  "homepage": "https://github.com/poptocrack/overlord",
  "type": "module",
  "main": "dist/electron/main.js",
  "bin": {
    "overlord": "./bin/overlord.js"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:electron": "npm run build:electron && ELECTRON_ENABLE_LOGGING=1 ELECTRON_ENABLE_STACK_DUMPING=1 electron dist/electron/main.js",
    "postinstall": "bash scripts/setup-rtk.sh",
    "build": "vite build",
    "build:electron": "vite build && tsc",
    "prepare:electron-package": "node scripts/prepare-electron-package.mjs",
    "dist:electron": "npm run build:electron && npm run prepare:electron-package && cd .electron-package && node --max-old-space-size=8192 ../node_modules/electron-builder/cli.js",
    "dist:electron:mac": "npm run build:electron && npm run prepare:electron-package && cd .electron-package && node --max-old-space-size=8192 ../node_modules/electron-builder/cli.js --mac",
    "dist:electron:win": "npm run build:electron && npm run prepare:electron-package && cd .electron-package && node --max-old-space-size=8192 ../node_modules/electron-builder/cli.js --win",
    "dist:electron:linux": "npm run build:electron && npm run prepare:electron-package && cd .electron-package && node --max-old-space-size=8192 ../node_modules/electron-builder/cli.js --linux",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "build": {
    "appId": "com.overlord.app",
    "productName": "Overlord",
    "copyright": "Copyright © 2026 Overlord",
    "asar": false,
    "directories": {
      "buildResources": "electron/assets",
      "output": "release"
    },
    "npmRebuild": false,
    "compression": "normal",
    "files": [
      "dist/**/*",
      "electron/assets/**/*",
      "package.json",
      "public/**/*",
      "!node_modules/@colbymchenry/codegraph/node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!@colbymchenry/codegraph/node_modules/better-sqlite3/**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": null,
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "msi": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets",
      "category": "Development",
      "maintainer": "Overlord <hello@poptocrack.com>"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@colbymchenry/codegraph": "^0.7.3",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "lucide-react": "^1.7.0",
    "open": "^11.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.1"
  }
}
